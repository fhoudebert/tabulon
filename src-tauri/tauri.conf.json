{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tabulon",
  "version": "0.1.0",
  "identifier": "fr.biscandine.tabulon",
  "build": {
    "frontendDist": [
      "../app",
      "../dist"
    ]
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null,
      "headers": {
        "Cross-Origin-Opener-Policy": "same-origin",
        "Cross-Origin-Embedder-Policy": "require-corp"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "cli": {
      "description": "Tabulon",
      "args": [
        {
          "name": "no-autoupdate",
          "description": "Disable the startup update check (no-op while tauri-plugin-updater is disabled, see ARCHITECTURE.md)"
        }
      ]
    }
  }
}
