{
  "name": "tabulon",
  "description": "Desktop application for playing board games (Tauri)",
  "version": "0.3.0",
  "productName": "Tabulon",
  "keywords": [
    "board games",
    "chess",
    "draughts",
    "tauri",
    "javascript"
  ],
  "homepage": "https://github.com/fhoudebert/tabulon",
  "author": {
    "name": "fhoudebert"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/fhoudebert/tabulon"
  },
  "license": "AGPL-3.0",
  "scripts": {
    "dev": "node scripts/check-dist.mjs && tauri dev",
    "build": "node scripts/check-dist.mjs && npm run build:frontend && tauri build",
    "build:frontend": "npm --prefix app install --omit=dev",
    "lint": "node_modules/jshint/bin/jshint app/content/*.js || true",
    "tauri": "tauri",
    "test": "node tests/run-tests.mjs",
    "check:dist": "node scripts/check-dist.mjs"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "jshint": "^2.13.6"
  },
  "overrides": {
    "graceful-fs": "^4.2.11"
  }
}
